# Meta Ads API
META_ACCESS_TOKEN=seu_token_meta
META_AD_ACCOUNT_ID=act_1234567890
META_API_VERSION=v21.0
# Opcional: fallback para numero do WhatsApp por page_id quando a Meta API nao retornar
# Exemplo: {"123456789012345":"+55 11 99999-9999"}
META_WHATSAPP_NUMBER_BY_PAGE_ID_JSON=
# Opcional: fallback para numero do WhatsApp por adset_id quando promoted_object/page vier vazio
# Exemplo: {"120244553890880274":"+55 11 98888-7777"}
META_WHATSAPP_NUMBER_BY_ADSET_ID_JSON=
# Opcional: ativa fallback pesado por preview HTML para tentar extrair destino final
# Recomendado manter 0 em producao e usar 1 apenas para diagnostico
META_DESTINATION_PREVIEW_FALLBACK=0

# URL base local para geracao de PDF
APP_BASE_URL=http://localhost:3000
# Opcional (ambiente local): caminho absoluto do Chrome para geracao de PDF com puppeteer-core
# CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Opcional: guardas analíticos mínimos para insights (evita alertas com baixa amostra)
INSIGHTS_MIN_IMPRESSIONS=1000
INSIGHTS_MIN_CLICKS=30
INSIGHTS_MIN_RESULTS=5

# Opcional: baseline da conta por objetivo (JSON)
# Exemplo: {"TRAFFIC":{"ctr":1.1,"cpc":2.6},"ENGAGEMENT":{"ctr":0.9,"cpc":2.2}}
INSIGHTS_BASELINE_ACCOUNT_JSON=

# Opcional: baseline por vertical e objetivo (JSON)
# Exemplo: {"Agrotitan":{"ENGAGEMENT":{"ctr":1.0,"cpc":2.4}},"Construshow":{"TRAFFIC":{"ctr":1.3,"cpc":2.9}}}
INSIGHTS_BASELINE_BY_VERTICAL_JSON=

# Teto mensal por vertical (BRL)
VERTICAL_MONTHLY_CAP_BRL=535

# Fuso para exibicao de datas
APP_TIMEZONE=America/Sao_Paulo
